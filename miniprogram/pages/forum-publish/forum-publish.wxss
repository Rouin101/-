page {
  background-color: #f5f5f5;
  height: 100%;
}

.publish-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.cancel-btn { color: #666; font-size: 30rpx; }
.page-title { font-size: 32rpx; font-weight: bold; }
.placeholder { width: 60rpx; } /* 占位宽度与取消按钮大致相同 */

/* 输入区域 */
.input-wrapper {
  flex: 1;
  padding: 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
}

.title-input {
  font-size: 32rpx;
  font-weight: bold;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.content-textarea {
  flex: 1;
  width: 100%;
  font-size: 30rpx;
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-bar {
  padding: 20rpx 30rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #eee;
}

.word-count {
  color: #999;
  font-size: 24rpx;
}

.publish-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
  padding: 0;
}