/* 页面背景 */
page {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  height: 100%;
}

.publish-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(107,53,160,0.1);
}
.cancel-btn {
  color: #6B35A0;
  font-size: 30rpx;
  font-weight: 500;
}
.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #6B35A0;
}
.placeholder {
  width: 60rpx;
}

/* 输入区域卡片 */
.input-wrapper {
  flex: 1;
  padding: 30rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  margin: 20rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
}

.title-input {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d2b3e;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(107,53,160,0.1);
  margin-bottom: 20rpx;
}

.content-textarea {
  flex: 1;
  width: 100%;
  font-size: 30rpx;
  line-height: 1.6;
  color: #444;
}

/* 底部操作栏 */
.bottom-bar {
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(107,53,160,0.1);
}

.word-count {
  color: #b0a8d0;
  font-size: 24rpx;
}

.publish-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.35);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 35rpx;
  padding: 0;
  border: none;
  transition: all 0.2s;
}
.publish-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.4);
}
.publish-btn::after {
  border: none;
}