<view class="container">
  <!-- 帖子列表展示区域 -->
  <scroll-view class="post-list" scroll-y enhanced="true">
    <block wx:for="{{postList}}" wx:key="_id">
      <view class="post-item">
        <view class="post-content">
          <text class="author">{{item.author}}</text>
          <text class="content">{{item.content}}</text>
          <text class="time">{{item.createTime}}</text>
        </view>

        <!-- 回复列表展示 -->
        <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0}}">
          <block wx:for="{{item.replies}}" wx:for-item="reply" wx:key="id">
            <view class="reply-item">
              <text class="reply-author">{{reply.author}}:</text>
              <text class="reply-content">{{reply.content}}</text>
            </view>
          </block>
        </view>

        <!-- 回复按钮：点击跳转到新的回复页面，并带上帖子ID和作者名 -->
        <view class="action-row">
          <button class="reply-btn" bindtap="goToReply" 
                  data-postid="{{item._id}}" 
                  data-author="{{item.author}}">
            回复
          </button>
        </view>
      </view>
    </block>
    
    <!-- 底部加载提示 -->
    <view class="loading-tip">没有更多了~</view>
  </scroll-view>

  <!-- 悬浮发帖按钮：点击跳转到新的发帖页面 -->
  <view class="fab-btn" bindtap="goToPublish">
    <text class="plus-icon">✍️ 我要发帖</text>
  </view>
</view>