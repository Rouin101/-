<view class="container">
  <!-- 帖子列表展示区域 -->
  <scroll-view class="post-list" scroll-y enhanced="true">
    <block wx:for="{{postList}}" wx:key="_id">
      <navigator class="post-item" url="/pages/forum-detail/forum-detail?id={{item._id}}">
        
        <!-- 顶部：头像和昵称（横向排列，垂直居中） -->
        <view class="user-info-row">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <text class="author">{{item.nickname}}</text>
        </view>

        <!-- 中间：正文内容（独占一行，保留换行和空格格式） -->
        <view class="content" style="white-space: pre-wrap;">{{item.content}}</view>
        
        <!-- 底部：发布时间（靠右） -->
        <text class="time">{{item.createTime}}</text>

        <!-- 回复列表展示 -->
        <view class="reply-list" wx:if="{{item.replies.length > 0}}">
          <!-- 1. 给头像们加一个包裹层 -->
          <view class="reply-avatars">
            <block wx:for="{{item.replies}}" wx:key="_id" wx:for-item="reply">
              <image 
                class="reply-avatar" 
                wx:if="{{index < 12}}"
                src="{{reply.avatar}}" 
              />
            </block>
          </view>
          
          <!-- 2. 全部回复文字（会自动被推到最右侧） -->
          <view class="reply-more">全部回复</view>
        </view>
          
        <!-- 回复按钮 -->
        <view class="action-row">
          <button class="reply-btn" bindtap="goToReply" 
                  data-postid="{{item._id}}" 
                  data-nickname="{{item.nickname}}">
            回复
          </button>
        </view>
          
      </navigator>
          
    </block>
          
         

    
    <!-- 底部加载提示 -->
    <view class="loading-tip">没有更多了~</view>
  </scroll-view>

  <!-- 悬浮发帖按钮 -->
  <view class="fab-btn" bindtap="goToPublish">
    <text class="plus-icon">✍️ 我要发帖</text>
  </view>
</view>