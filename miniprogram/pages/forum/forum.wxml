<view class="container">
  <scroll-view class="post-list" scroll-y>
    <block wx:for="{{postList}}" wx:key="_id">
      <view class="post-item">
        <view class="post-content">
          <text class="author">{{item.author}}</text>
          <text class="content">{{item.content}}</text>
          <text class="time">{{item.createTime}}</text>
        </view>

        <!-- 评论列表（100%能显示） -->
        <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0}}">
          <view class="reply-item" wx:for="{{item.replies}}" wx:key="index">
            <text class="reply-author">{{item.author}}：</text>
            <text class="reply-content">{{item.content}}</text>
          </view>
        </view>

        <!-- ✅ 这里修复！！！data-postid 必须写对！ -->
        <button class="reply-btn" bindtap="openReplyModal" data-postid="{{item._id}}">
          回复
        </button>
        
        <button 
          class="reply-btn" 
          style="color:#f44336; margin-top:10rpx;" 
          bindtap="deletePost" 
          data-id="{{item._id}}">
          删除
        </button>

      </view>
    </block>
  </scroll-view>

  <view class="bottom-input">
    <input class="input-field" placeholder="分享你的想法..." bindinput="onPostInput" value="{{postContent}}" />
    <button class="post-btn" bindtap="submitPost">发布</button>
  </view>

  <view class="reply-modal" wx:if="{{showReplyModal}}">
    <view class="modal-content">
      <view class="modal-title">回复帖子</view>
      <input class="reply-input" placeholder="写下你的回复..." bindinput="onReplyInput" value="{{replyContent}}" />
      <view class="modal-buttons">
        <button class="cancel-btn" bindtap="closeReplyModal">取消</button>
        <button class="confirm-btn" bindtap="submitReply">发送</button>
      </view>
    </view>
  </view>
</view>