/* 容器占满全屏 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh; /* 占满全屏高度 */
  box-sizing: border-box;
}

/* 帖子列表区域 */
.post-list {
  flex: 1; /* 占据剩余所有空间 */
  height: 0; /* 解决 flex 子元素高度溢出问题的关键 hack */
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

/* 帖子卡片 */
.post-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.post-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.author { font-weight: bold; color: #333; }
.content { color: #555; line-height: 1.6; }
.time { color: #999; font-size: 24rpx; text-align: right; }

/* 回复列表 */
.reply-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}
.reply-item {
  font-size: 26rpx;
  margin-bottom: 10rpx;
  color: #666;
}
.reply-author { color: #576b95; font-weight: 500; }

/* 底部输入框区域 */
.bottom-input {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.input-field {
  flex: 1;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.post-btn {
  width: 160rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 弹窗遮罩 */
.reply-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); /* 半透明黑底 */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.modal-title { font-size: 32rpx; font-weight: bold; }
.close-icon { font-size: 40rpx; color: #999; }

.reply-input {
  width: 100%;
  border: 1rpx solid #ddd;
  padding: 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  height: 100rpx; /* 多行回复建议给个固定高度 */
}

.modal-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}
.cancel-btn { background: #f5f5f5; color: #666; }
.confirm-btn { background: #07c160; color: #fff; }

.btn-hover { opacity: 0.8; }
.loading-tip { text-align: center; color: #999; padding: 20rpx 0; font-size: 24rpx; }