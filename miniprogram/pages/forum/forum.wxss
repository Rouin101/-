/* 容器占满全屏 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

/* 帖子列表区域 */
.post-list {
  flex: 1;
  height: 0;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 帖子卡片 */
.post-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 新增：头像和昵称的横向排列容器 */
.user-info-row {
  display: flex;
  flex-direction: row;
  align-items: center; /* 核心：让头像和昵称垂直居中对齐 */
  margin-bottom: 16rpx; /* 和下方正文拉开一点距离 */
}

/* 主贴头像样式 */
.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0; /* 防止被挤压 */
  margin-right: 16rpx; /* 头像和昵称之间的间距 */
  background-color: #eee;
}

/* 昵称样式 */
.author { 
  font-size: 28rpx;
  font-weight: bold; 
  color: #333; 
}

/* 正文内容：独立出来独占一行 */
.content { 
  font-size: 30rpx;
  color: #444; 
  line-height: 1.6; 
  margin-bottom: 12rpx; /* 和下方时间拉开距离 */
  word-break: break-all;
}

/* 发布时间 */
.time { 
  display: block; /* 让它独占一行，才能 text-align: right */
  color: #bbb; 
  font-size: 22rpx; 
  text-align: right;
  margin-bottom: 16rpx;
}

/* 回复列表 */
.reply-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx;
}

/* 单条回复的整体容器：改为纵向排列 */
.reply-item {
  display: flex;
  flex-direction: column; 
  font-size: 26rpx;
  margin-bottom: 20rpx;
  color: #666;
  line-height: 1.5;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0; /* 加个淡淡的底部分割线 */
}

.reply-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

/* 新增：回复的头部（包裹头像和昵称，实现中心对齐） */
.reply-header {
  display: flex;
  flex-direction: row;
  align-items: center; /* 核心：头像和昵称垂直居中对齐 */
  margin-bottom: 8rpx; /* 头部和下方内容拉开一点间距 */
}

/* 回复列表里的小头像 */
.avatar-small {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0; /* 防止头像被挤压变形 */
  margin-right: 12rpx; /* 头像和昵称的间距 */
  background-color: #eee;
}

/* 回复的作者名 */
.reply-author { 
  color: #576b95; 
  font-weight: 500; 
  font-size: 26rpx;
}

/* 回复的正文内容：独立换行 */
.reply-content {
  color: #666;
  word-break: break-all; /* 防止超长文本撑破布局 */
  padding-left: 56rpx; /* 视觉优化：让内容左边缘和上方昵称对齐 (头像44 + 间距12) */
}

/* 回复按钮行 */
.action-row {
  text-align: right;
}

.reply-btn {
  display: inline-block;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background-color: #f0f2f5;
  color: #576b95;
  border-radius: 28rpx;
  margin: 0;
}
.reply-btn::after { border: none; }
/* 底部加载提示 */
.loading-tip { 
  text-align: center; 
  color: #ccc; 
  padding: 30rpx 0; 
  font-size: 24rpx; 
}

/* 悬浮发帖按钮 */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  background-color: #07c160;
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.plus-icon {
  font-size: 28rpx;
  font-weight: 500;
}