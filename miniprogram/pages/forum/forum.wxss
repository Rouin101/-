.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}
.post-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  margin-bottom: 120rpx;
}
.post-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.post-content .author {
  font-weight: bold;
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}
.post-content .content {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}
.post-content .time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}
.reply-list {
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
.reply-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}
.reply-author {
  color: #07c160;
  font-weight: 500;
}
.reply-btn {
  background-color: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.5;
  margin-right: 10rpx;
}

/* 只追加 删除按钮样式（和你风格完全统一） */
.delete-btn {
  background-color: #ffebee;
  color: #f44336;
}

.bottom-input {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #eee;
}
.input-field {
  flex: 1;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}
.post-btn {
  background-color: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
}
.reply-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  background-color: #fff;
  width: 80%;
  border-radius: 16rpx;
  padding: 32rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
}
.reply-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}
.modal-buttons {
  display: flex;
  justify-content: space-between;
}
.cancel-btn {
  background-color: #f0f0f0;
  color: #666;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}
.confirm-btn {
  background-color: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}