/* ========= 全局容器（淡紫渐变背景） ========= */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
}

/* ========= 帖子列表区域 ========= */
.post-list {
  flex: 1;
  height: 0;
  padding: 20rpx;
  box-sizing: border-box;
}

/* ========= 帖子卡片（白色圆角阴影） ========= */
.post-item {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
  border: 1rpx solid rgba(107,53,160,0.06);
  transition: all 0.2s;
}
.post-item:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(107,53,160,0.12);
}

/* ========= 头像与昵称行 ========= */
.user-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
  background-color: #eee;
  border: 2rpx solid rgba(107,53,160,0.1);
}

.author {
  font-size: 28rpx;
  font-weight: bold;
  color: #6B35A0;           /* 昵称用主紫色 */
}

/* ========= 正文内容 ========= */
.content {
  font-size: 30rpx;
  color: #2d2b3e;
  line-height: 1.6;
  margin-bottom: 12rpx;
  word-break: break-all;
}

/* ========= 发布时间 ========= */
.time {
  display: block;
  color: #b0a8d0;
  font-size: 22rpx;
  text-align: right;
  margin-bottom: 16rpx;
}

/* ========= 回复列表区域 ========= */
.reply-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(107,53,160,0.1);
  background-color: #faf5ff;
  border-radius: 16rpx;
  padding: 16rpx;
}

/* ========= 单条回复 ========= */
.reply-item {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  color: #555;
  line-height: 1.5;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(107,53,160,0.08);
}

.reply-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

/* 回复头部（头像+昵称） */
.reply-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.avatar-small {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 12rpx;
  background-color: #eee;
  border: 1rpx solid rgba(107,53,160,0.12);
}

.reply-author {
  color: #6B35A0;            /* 回复者昵称紫色 */
  font-weight: 600;
  font-size: 26rpx;
}

/* 回复正文 */
.reply-content {
  color: #4a4a5a;
  word-break: break-all;
  padding-left: 56rpx;        /* 与昵称对齐 */
}
/* 回复列表容器 */
.reply-list {
  display: flex;
  flex-direction: row;
  height:25px;
  /* --- 修改这里 --- */
  align-items: flex-start; /* 改成顶部对齐，解决垂直掉落问题 */
  
  padding-left: 20rpx;
  margin-top: 15rpx;
  overflow: visible;
  flex-wrap: nowrap;
}

/* 回复头像 */
.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  
  /* 这里的重叠数值可以是负数，也可以根据需求调整 */
  margin-left: -10rpx; 
  
  flex-shrink: 0;
}

.reply-avatar:first-child {
  margin-left: 0;
}
/* ========= 回复按钮 ========= */
.action-row {
  text-align: right;
}

.reply-btn {
  display: inline-block;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background-color: #f3e8f9;      /* 淡紫色背景 */
  color: #6B35A0;                 /* 紫色文字 */
  border-radius: 28rpx;
  margin: 0;
  font-weight: 500;
  transition: all 0.2s;
}
.reply-btn:active {
  background: #e9d4f7;
}
.reply-btn::after {
  border: none;
}

/* ========= 底部加载提示 ========= */
.loading-tip {
  text-align: center;
  color: #b0a8d0;
  padding: 30rpx 0;
  font-size: 24rpx;
  font-weight: 500;
}

/* ========= 悬浮发帖按钮（紫色渐变，替代原绿色） ========= */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: all 0.2s;
}
.fab-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(107, 53, 160, 0.5);
}

.plus-icon {
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 8rpx;
}