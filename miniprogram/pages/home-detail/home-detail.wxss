page {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  height: 100%;
}

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.detail-swiper {
  width: 100%;
  height: 700rpx;
  background-color: #f3e8f9;
}

.detail-image {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  margin: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #6B35A0;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.detail-content {
  font-size: 30rpx;
  color: #3a3548;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-user {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid rgba(107,53,160,0.1);
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
}

.detail-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid rgba(107,53,160,0.2);
}

.detail-nickname {
  font-size: 28rpx;
  color: #6B35A0;
  font-weight: 600;
}