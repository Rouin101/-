page {
  background-color: #fff;
  height: 100%;
}

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.detail-swiper {
  width: 100%;
  height: 700rpx; /* 【修改点】固定高度，或者根据需要调整 */
  background-color: #f5f5f5;
}

.detail-image {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-body {
  padding: 30rpx;
  flex: 1; /* 让内容区域占据剩余空间 */
  overflow-y: auto; /* 内容过多时允许滚动 */
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.detail-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
  white-space: pre-wrap; /* 保留换行 */
}

.detail-user {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  background: #fff;
}

.detail-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.detail-nickname {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}