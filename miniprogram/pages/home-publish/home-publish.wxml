<view class="container">
  
  <!-- 1. 图片上传与预览区域 -->
  <view class="image-section">
    
    <view class="image-list">
      <view class="image-item" wx:for="{{tempFilePaths}}" wx:key="*this">
        <image class="preview-img" src="{{item}}" mode="aspectFill"></image>
        <view class="delete-btn" data-index="{{index}}" bindtap="deleteImage">×</view>
      </view>
    </view>
    
    <view class="upload-btn" bindtap="chooseImage">
      <text class="upload-icon">+</text>
      <text class="upload-text">添加图片</text>
    </view>
  
  </view>

  <!-- 2. 标题输入 -->
  <view class="form-item">
    <input 
      class="title-input" 
      placeholder="填写标题会有更多赞哦~" 
      value="{{title}}" 
      bindinput="onTitleInput" 
      maxlength="20"
    />
  </view>

  
  <!-- 3. 正文内容输入 -->
  <view class="form-item content-wrapper">
    <textarea 
      class="publish-textarea" 
      placeholder="请输入正文内容..." 
      value="{{content}}" 
      bindinput="onContentInput"
      maxlength="-1" 
    ></textarea>
  </view>
  

  <!-- 4. 底部操作栏 -->
  <view class="bottom-bar">
    <button class="btn-cancel" bindtap="goBack">取消</button>
    <button class="btn-publish" bindtap="confirmPublish">发出</button>
  </view>
</view>