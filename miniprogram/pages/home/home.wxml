<scroll-view scroll-y class="container">
  <view class="waterfall">
    <view class="card" wx:for="{{noteList}}" wx:key="_id">
      <!-- 点击卡片显示详情 -->
      <view bindtap="showDetail" data-item="{{item}}">
        <image 
          class="card-img" 
          src="{{item.image}}" 
          mode="widthFix" 
          lazy-load
        ></image>
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
            <text class="nickname">{{item.nickname}}</text>
            <text class="likes">❤️ {{item.likes || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 悬浮发布按钮 -->
<view class="fab-btn" bindtap="openPublishModal">
  <text class="plus-icon">+</text>
</view>

<!-- --- 修复：发帖弹窗 --- -->
<view class="custom-modal" wx:if="{{showPublishModal}}">
  <!-- 遮罩层：只负责点击关闭，不再拦截所有触摸事件 -->
  <view class="modal-mask" bindtap="closePublishModal"></view>
  
  <view class="modal-box">
    <view class="modal-header">
      <text class="modal-title">发布笔记</text>
      <text class="modal-close" bindtap="closePublishModal">×</text>
    </view>
    
    <scroll-view scroll-y class="modal-body">
      <!-- 标题输入 -->
      <input 
        class="input-title" 
        placeholder="填写标题..." 
        value="{{tempTitle}}" 
        bindinput="onTitleInput"
        adjust-position="{{false}}" 
        focus="{{showPublishModal}}"
      />
      
      <!-- 内容输入 (多行) -->
      <textarea 
        class="input-content" 
        placeholder="填写正文内容..." 
        value="{{tempContent}}" 
        bindinput="onContentInput" 
        auto-height
        adjust-position="{{false}}"
        fixed="{{true}}"
      />
    </scroll-view>
    
    <view class="modal-footer">
      <button class="btn-submit" bindtap="confirmPublish">发布</button>
    </view>
  </view>
</view>

<!-- --- 2. 修改：详情弹窗 (增加内容显示) --- -->
<view class="detail-modal" wx:if="{{currentDetail}}" catchtouchmove="true">
  <view class="modal-mask" bindtap="hideDetail"></view>
  <view class="modal-content">
    <view class="close-btn" bindtap="hideDetail">×</view>
    
    <image class="detail-image" src="{{currentDetail.image}}" mode="widthFix"></image>
    
    <view class="detail-body">
      <view class="detail-title">{{currentDetail.title}}</view>
      <!-- 新增：显示正文内容 -->
      <view class="detail-content" wx:if="{{currentDetail.content}}">
        {{currentDetail.content}}
      </view>
    </view>

    <view class="detail-user">
      <image class="detail-avatar" src="{{currentDetail.avatar}}"></image>
      <text class="detail-nickname">{{currentDetail.nickname}}</text>
    </view>
  </view>
</view>