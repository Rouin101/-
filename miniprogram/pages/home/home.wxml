<scroll-view scroll-y class="container">
  <view class="waterfall">
    <view class="card" wx:for="{{noteList}}" wx:key="_id">
      
      <!-- 修改点：使用 navigator 跳转，并传递 item._id -->
      <navigator url="/pages/home-detail/home-detail?id={{item._id}}">
        <image 
          class="card-img" 
          src="{{item.image}}" 
          mode="widthFix" 
          lazy-load
        ></image>
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
            <text class="nickname">{{item.nickname}}</text>
            <text class="likes">❤️ {{item.likes || 0}}</text>
          </view>
        </view>
      </navigator>

    </view>
  </view>
</scroll-view>

<!-- 悬浮发布按钮 (保持不变) -->
<navigator url="/pages/home-publish/home-publish" class="fab-btn" hover-class="none">
  <text class="plus-icon">+</text>
</navigator>

