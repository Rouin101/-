page {
  background-color: #f5f5f5;
  height: 100%;
}

.container {
  height: 100vh;
  box-sizing: border-box;
  padding: 10rpx;
}

/* 瀑布流样式 */
.waterfall {
  column-count: 2;
  column-gap: 10rpx;
}

.card {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
  break-inside: avoid;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.card-img {
  width: 100%;        /* 宽度占满列宽 */
  
  display: block;     /* 消除图片底部缝隙 */
  background-color: #f5f5f5; /* 加个底色，防止加载时透明 */
}

.card-content {
  padding: 20rpx;       /* 增加一点内边距 */
}

.card-title {
  font-size: 30rpx;     /* 稍微调大一点字体 */
  color: #333;
  font-weight: 500;     /* 加粗一点点 */
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2; /* 限制最多两行 */
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;  /* 标题和底部用户信息的间距 */
}

.card-footer {
  display: flex;
  align-items: center;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.nickname {
  font-size: 22rpx;
  color: #666;
  flex: 1;
}

.likes {
  font-size: 22rpx;
  color: #999;
}

/* --- 新增：悬浮按钮样式 --- */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(45deg, #ff2442, #ff6b81); /* 小红书红渐变 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 36, 66, 0.4);
  z-index: 999;
}

.plus-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000; /* 确保在最上层 */
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.7); /* 黑色半透明 */
}

.modal-content {
  position: relative;
  z-index: 1001;
  width: 90%;
  max-height: 90%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out; /* 简单的入场动画 */
}

@keyframes slideUp {
  from { transform: translateY(50px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 60rpx;
  color: #fff;
  z-index: 1002;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
}

.detail-image {
  width: 100%;
  display: block;
}

.detail-title {
  padding: 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
}

.detail-user {
  display: flex;
  align-items: center;
  padding: 0 30rpx 30rpx;
}

.detail-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.detail-nickname {
  font-size: 28rpx;
  color: #666;
}

/* --- 修复：发帖弹窗样式 --- */
.custom-modal {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 2000;
  /* 使用 Flex 居中 */
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-mask {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  /* 关键点：让遮罩层不响应触摸移动，避免影响输入 */
  pointer-events: auto; 
}

.modal-box {
  position: relative;
  z-index: 2001;
  width: 85%;
  max-height: 80vh; /* 限制最大高度 */
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0; /* 防止头部被压缩 */
}

.modal-title { font-size: 32rpx; font-weight: bold; }
.modal-close { font-size: 50rpx; color: #999; }

/* 关键点：中间内容区域允许滚动 */
.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch; /* iOS 顺滑滚动 */
}

.input-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
  /* 确保输入框可见 */
  width: 100%; 
  box-sizing: border-box;
}

.input-content {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  min-height: 150rpx;
  line-height: 1.5;
}

.modal-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.btn-submit {
  background: linear-gradient(45deg, #ff2442, #ff6b81);
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none; /* 去除默认边框 */
}
/* --- 修改：详情页样式 (增加内容排版) --- */
.detail-body {
  padding: 30rpx;
  padding-bottom: 10rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

/* 新增：正文内容样式 */
.detail-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
  white-space: pre-wrap; /* 保留换行符，让内容自然换行 */
}

.detail-user {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
}