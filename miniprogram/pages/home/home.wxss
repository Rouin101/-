page {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  height: 100%;
}

.container {
  height: 100vh;
  box-sizing: border-box;
  padding: 10rpx;
}

/* --- 瀑布流 --- */
.waterfall {
  column-count: 2;
  column-gap: 10rpx;
}

.card {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8rpx);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
  break-inside: avoid;
  box-shadow: 0 6rpx 20rpx rgba(107, 53, 160, 0.08);
  border: 1rpx solid rgba(107,53,160,0.06);
  transition: all 0.2s;
}
.card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(107,53,160,0.12);
}

.card-img {
  width: 100%;
  display: block;
  background-color: #f3e8f9;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  font-size: 30rpx;
  color: #6B35A0;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-footer {
  display: flex;
  align-items: center;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  border: 2rpx solid rgba(107,53,160,0.2);
}

.nickname {
  font-size: 22rpx;
  color: #6B35A0;
  flex: 1;
  font-weight: 500;
}

.likes {
  font-size: 22rpx;
  color: #b0a8d0;
}

/* --- 悬浮发帖按钮（紫色渐变） --- */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(107, 53, 160, 0.45);
  z-index: 999;
  transition: all 0.2s;
}
.fab-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(107, 53, 160, 0.5);
}

.plus-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
}