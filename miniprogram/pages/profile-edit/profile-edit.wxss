/* 全局页面背景 */
page {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;               /* 原 #f5f5f5 去掉，用 page 背景 */
}

.scroll-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(107, 53, 160, 0.1);
  margin: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #eedef7;
  border: 4rpx solid #c7abd4;
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.15);
}

.tip {
  margin-top: 24rpx;
  color: #6B35A0;
  font-size: 24rpx;
  font-weight: 500;
}

/* 表单容器 */
.form-container {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 48rpx;
}

/* 标签：保留竖线装饰，颜色改紫 */
.label {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #6B35A0;                         /* 原 #888 → 主紫色 */
  font-weight: 600;                       /* 加粗一点更显眼 */
  padding-left: 4rpx;
}

.label::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 26rpx;
  background-color: #6B35A0;              /* 原 #4f8ff7 → 紫色 */
  margin-right: 12rpx;
  border-radius: 4rpx;
}

/* 输入框 & 文本域 */
.input,
.textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8rpx);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  border: 1rpx solid rgba(107, 53, 160, 0.25);   /* 原 #e5e5e5 → 淡紫边框 */
  min-height: 88rpx;
  transition: all 0.2s;
}

/* 聚焦时加强紫色光晕 */
.input:focus,
.textarea:focus {
  border-color: #6B35A0;
  box-shadow: 0 0 0 4rpx rgba(107, 53, 160, 0.1);
}

/* 占位符颜色 */
.input::placeholder,
.textarea::placeholder {
  line-height: normal;
  color: #b0a8d0;                         /* 原 #bbb → 淡紫 */
}

.textarea {
  height: 260rpx;
  padding-top: 24rpx;
  line-height: 1.6;
  resize: none;
}

/* 保存按钮：紫色渐变 */
.save-btn {
  position: fixed;
  bottom: 20rpx;
  left: 40rpx;
  right: 40rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.35);
  color: #fff;
  border-radius: 40rpx;                   /* 加大圆角，更柔和 */
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  z-index: 100;
  transition: all 0.2s;
  letter-spacing: 2rpx;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  background: linear-gradient(135deg, #6B35A0, #572d8a);
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.4);
}