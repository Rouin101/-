/* 页面背景：淡紫渐变 */
page {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;
}

.scroll-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(107, 53, 160, 0.1);
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #eedef7;
  border: 4rpx solid #6B35A0;
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.15);
}

.tip {
  margin-top: 24rpx;
  color: #6B35A0;
  font-size: 24rpx;
  font-weight: 500;
}

/* 表单容器 */
.form-container {
  padding: 30rpx 40rpx 40rpx 40rpx;
}

.form-item {
  margin-bottom: 48rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #6B35A0;
}

.input,
.textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8rpx);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #2d2b3e;
  border: 1rpx solid rgba(107, 53, 160, 0.2);
  transition: all 0.2s;
}

.input:focus,
.textarea:focus {
  border-color: #6B35A0;
  box-shadow: 0 0 0 4rpx rgba(107, 53, 160, 0.1);
}

.input::placeholder,
.textarea::placeholder {
  color: #b0a8d0;
}

.textarea {
  height: 220rpx;
  resize: none;
}

/* 保存按钮：紫色渐变，固定底部 */
.save-btn {
  position: fixed;
  bottom: 20rpx;
  left: 40rpx;
  right: 40rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.35);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  z-index: 100;
  transition: all 0.2s;
  letter-spacing: 2rpx;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  background: linear-gradient(135deg, #6B35A0, #572d8a);
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.4);
}