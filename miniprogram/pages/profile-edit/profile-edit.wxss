.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.scroll-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx 40rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #eee;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tip {
  margin-top: 24rpx;
  color: #999;
  font-size: 24rpx;
}

.form-container {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 48rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.input,
.textarea {
  width: 100%;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e5e5e5;
}

.input::placeholder,
.textarea::placeholder {
  color: #bbb;
}

.textarea {
  height: 220rpx;
  resize: none;
}

.save-btn {
  position: fixed;
  bottom: 20rpx;
  left: 40rpx;
  right: 40rpx;
  height: 80rpx;
  background: #4f8ff7;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  z-index: 100;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  background: #3a7dd8;
}