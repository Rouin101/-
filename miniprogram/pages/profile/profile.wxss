/* ===== 页面 ===== */
.container {
  width: 100%;
  min-height: 100vh;

  background: #f5f7fb;

  display: flex;
  flex-direction: column;

  /* 覆盖全局 container */
  align-items: stretch;

  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* ===== 顶部用户信息 ===== */
.profile-card {
  width: 100%;
  box-sizing: border-box;

  background: linear-gradient(135deg, #4f8ff7, #76b2ff);

  padding: 90rpx 36rpx 70rpx;

  display: flex;
  align-items: center;

  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;

  box-shadow: 0 8rpx 24rpx rgba(79, 143, 247, 0.25);
}

/* 头像 */
.avatar-wrap {
  width: 140rpx;
  height: 140rpx;

  border-radius: 50%;
  overflow: hidden;

  border: 6rpx solid rgba(255,255,255,0.9);

  flex-shrink: 0;

  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
}

.avatar {
  width: 100%;
  height: 100%;
}

/* 用户信息 */
.user-info {
  margin-left: 30rpx;

  display: flex;
  flex-direction: column;
  justify-content: center;

  min-width: 0;
}

.nickname {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
}

.bio {
  margin-top: 10rpx;

  font-size: 24rpx;
  color: rgba(255,255,255,0.85);

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 数据统计 ===== */
.score-card {
  margin: -35rpx 24rpx 0;

  background: #fff;

  border-radius: 24rpx;

  display: flex;
  align-items: center;

  padding: 36rpx 0;

  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);

  position: relative;
  z-index: 10;
}

.score-item {
  flex: 1;

  display: flex;
  flex-direction: column;
  align-items: center;

  padding: 0 10rpx;

  box-sizing: border-box;
}

.score-num {
  font-size: 52rpx;
  font-weight: bold;

  color: #4f8ff7;
}

.score-num.red {
  color: #ff5a5f;
}

.score-label {
  margin-top: 10rpx;

  font-size: 20rpx;
  color: #999;

  text-align: center;
}

.divider {
  width: 2rpx;
  height: 70rpx;

  background: #edf1f7;
}

/* ===== Tab ===== */
.tab-bar {
  margin: 36rpx 24rpx 24rpx;

  background: #fff;

  border-radius: 18rpx;

  display: flex;

  padding: 8rpx;

  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;

  text-align: center;

  padding: 20rpx 0;

  font-size: 28rpx;
  color: #777;

  border-radius: 14rpx;

  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4f8ff7, #6aa8ff);

  color: #fff;
  font-weight: 600;

  box-shadow: 0 4rpx 12rpx rgba(79,143,247,0.25);
}

/* ===== 提示 ===== */
.loading-tip,
.empty-tip {
  text-align: center;

  color: #aaa;
  font-size: 28rpx;

  padding: 100rpx 0;
}

/* ===== 列表 ===== */
.note-list {
  width: 100%;

  padding: 0 24rpx;

  box-sizing: border-box;

  display: flex;
  flex-direction: column;

  gap: 24rpx;
}

/* ===== 精选帖子 ===== */
.note-item {
  background: #fff;

  border-radius: 24rpx;

  overflow: hidden;

  display: flex;

  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);

  transition: transform 0.15s;
}

.note-item:active {
  transform: scale(0.98);
}

.note-img {
  width: 210rpx;
  height: 210rpx;

  flex-shrink: 0;

  background: #eee;
}

.note-content {
  flex: 1;

  padding: 24rpx;

  display: flex;
  flex-direction: column;
  justify-content: space-between;

  min-width: 0;
}

.note-title {
  font-size: 32rpx;
  font-weight: 600;

  color: #222;

  line-height: 1.5;

  word-break: break-all;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;

  overflow: hidden;
}

.note-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;

  margin-top: 20rpx;
}

.note-likes {
  font-size: 24rpx;

  color: #ff5a5f;

  background: #fff2f3;

  padding: 8rpx 16rpx;

  border-radius: 999rpx;
}

/* ===== 论坛帖子 ===== */
.forum-item {
  background: #fff;

  border-radius: 24rpx;

  padding: 28rpx;

  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);

  transition: transform 0.15s;
}

.forum-item:active {
  transform: scale(0.98);
}

.forum-content {
  font-size: 30rpx;

  color: #333;

  line-height: 1.7;

  word-break: break-all;

  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;

  overflow: hidden;
}

.forum-footer {
  margin-top: 24rpx;

  display: flex;
  justify-content: flex-end;
}

.forum-replies {
  font-size: 24rpx;

  color: #4f8ff7;

  background: #eef5ff;

  padding: 8rpx 18rpx;

  border-radius: 999rpx;
}

.edit-btn {
  margin-top: 18rpx;

  padding: 10rpx 24rpx;

  background: rgba(255,255,255,0.2);

  color: #fff;

  border-radius: 999rpx;

  font-size: 24rpx;

  align-self: flex-start;
}