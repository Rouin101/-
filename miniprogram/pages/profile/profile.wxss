/* ===== 全局背景 ===== */
.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* ===== 顶部用户信息卡片 ===== */
.profile-card {
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  padding: 100rpx 36rpx 70rpx;
  display: flex;
  align-items: flex-start;
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  box-shadow: 0 12rpx 36rpx rgba(107, 53, 160, 0.3);
}

/* 头像 */
.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255,255,255,0.95);
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
  margin-top: -10rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

/* 用户信息 */
.user-info {
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.nickname {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.bio {
  margin-top: 14rpx;
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 编辑资料 */
.edit-btn {
  margin-top: 20rpx;
  padding: 12rpx 30rpx;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10rpx);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  align-self: flex-start;
  border: 1rpx solid rgba(255,255,255,0.3);
  transition: all 0.2s;
}
.edit-btn:active {
  background: rgba(255,255,255,0.4);
  transform: scale(0.96);
}

/* ===== 数据统计卡片 ===== */
.score-card {
  margin: -35rpx 24rpx 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  box-shadow: 0 12rpx 40rpx rgba(107, 53, 160, 0.12);
  position: relative;
  z-index: 10;
  border: 1rpx solid rgba(107,53,160,0.08);
}

.score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.score-num {
  font-size: 56rpx;
  font-weight: 900;
  color: #6B35A0;
  letter-spacing: 1rpx;
}

.score-num.red {
  color: #6B35A0;
  text-shadow: 0 2rpx 8rpx rgba(107, 53, 160, 0.15);
}

.score-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  font-weight: 500;
}

.score-detail {
  font-size: 26rpx;
  color: #6B35A0;
  margin-top: 8rpx;
  font-weight: 600;
}

.divider {
  width: 2rpx;
  height: 70rpx;
  background: #e8e6f5;
}

/* ===== Tab 栏 ===== */
.tab-bar {
  margin: 36rpx 24rpx 24rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  display: flex;
  padding: 10rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #6B35A0;
  border-radius: 18rpx;
  transition: all 0.3s;
  font-weight: 500;
}

.tab-item.active {
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 6rpx 18rpx rgba(107, 53, 160, 0.3);
}

/* ===== 空状态 ===== */
.loading-tip,
.empty-tip {
  text-align: center;
  color: #b0a8d0;
  font-size: 28rpx;
  padding: 100rpx 0;
  font-weight: 500;
}

/* ===== 列表 ===== */
.note-list {
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.note-item {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8rpx);
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  display: flex;
  box-shadow: 0 8rpx 28rpx rgba(107, 53, 160, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1rpx solid rgba(107,53,160,0.06);
}
.note-item:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(107, 53, 160, 0.1);
}

.note-img {
  width: 210rpx;
  height: 210rpx;
  flex-shrink: 0;
  background: #eedef7;
}

.note-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.note-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e1b3a;
  line-height: 1.5;
  padding-right: 100rpx;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 20rpx;
}

.note-likes {
  font-size: 24rpx;
  color: #ef4444;
  background: #fef2f2;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

/* ===== 论坛帖子 ===== */
.forum-item {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8rpx);
  border-radius: 28rpx;
  position: relative;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(107, 53, 160, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1rpx solid rgba(107,53,160,0.06);
}
.forum-item:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(107, 53, 160, 0.1);
}

.forum-content {
  font-size: 28rpx;
  color: #2d2b3e;
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
  text-indent: 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
  overflow: hidden;
  text-overflow: ellipsis;
}

.forum-footer {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.forum-replies {
  font-size: 24rpx;
  color: #6B35A0;
  background: #f3e8f9;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.delete-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 77, 79, 0.1); /* 浅红色半透明背景 */
  color: #ff4d4f; /* 红色文字 */
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx; /* 胶囊圆角 */
  z-index: 10;
  border: 1rpx solid rgba(255, 77, 79, 0.3); /* 红色描边 */
  transition: all 0.2s;
}

/* 删除按钮点击按压效果 */
.delete-btn:active {
  background: #ff4d4f;
  color: #ffffff;
  transform: scale(0.95);
}