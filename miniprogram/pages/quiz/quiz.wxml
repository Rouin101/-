<!--pages/quiz/quiz.wxml-->
<view class="container">

  <!-- 开始页 -->
  <view class="home-full" wx:if="{{showHome}}">
    <view class="home-title">吴健雄 · 知识问答</view>
    <view class="home-subtitle">“世界物理女王”的生平知多少？</view>
    <view class="home-btns">
      <button class="start-btn" bindtap="startQuiz">开始答题</button>
      <button class="rank-btn-text" bindtap="goToRank">查看排行榜</button>
    </view>
  </view>

  <!-- 答题页 -->
  <view class="quiz-wrap" wx:if="{{showQuiz}}">
    <!-- 退出按钮 -->
    <view class="exit-btn" bindtap="exitQuiz" hover-class="exit-btn-hover">
      <text class="exit-icon">✕</text>
    </view>

    <view class="progress-bar">
      <view class="progress" style="width: {{(currentIndex + 1) / questions.length * 100+'%'}}"></view>
    </view>
    <view class="quiz-card">
      <view class="question-info">
        <text class="type-tag">{{questions[currentIndex].type === 'choice' ? '单选题' : '判断题'}}</text>
        <text class="count-text">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
      </view>
      <view class="question-content">{{questions[currentIndex].question}}</view>
      <view class="options-container">
        <view 
          class="option-item {{questions[currentIndex].userAnswer === index ? 'selected' : ''}}"
          wx:for="{{questions[currentIndex].options}}" 
          wx:key="index"
          bindtap="selectOption"
          data-index="{{index}}"
        >
          {{item}}
        </view>
      </view>
    </view>
    <view class="btn-row">
    <button class="prev-btn" bindtap="prevQuestion" disabled="{{currentIndex === 0}}">
      上一题
    </button>
    <button class="next-btn-fixed" bindtap="nextQuestion" disabled="{{questions[currentIndex].userAnswer === undefined}}">
      {{currentIndex === questions.length - 1 ? '提交结果' : '下一题'}}
    </button>
  </view>
</view>

    <!-- 头部标题区 -->
    <view class="hero">
      <image wx:if="{{headerImage}}" class="hero-image hero-image-large" src="{{headerImage}}" mode="aspectFill" binderror="onImageError" data-src="{{headerImage}}"></image>
      <text class="hero-title">吴健雄 · 时光轨迹</text>
      <text class="hero-subtitle">世界物理女王 · 核物理先驱</text>
      <view class="hero-line"></view>
    </view>

    <!-- 时间线列表 -->
    <view class="timeline-list">
      <block wx:for="{{timelineList}}" wx:key="index">
        <view class="timeline-item" bindtap="onTapEvent" data-event="{{item}}">
          <view class="timeline-left">
            <view class="timeline-year">{{item.year}}</view>
            <view class="timeline-dot-wrapper">
              <view class="timeline-dot"></view>
              <view class="timeline-line" wx:if="{{index < timelineList.length - 1}}"></view>
            </view>
          </view>
          
            <view class="timeline-right">
              <view class="timeline-card">
                <view class="card-content">
                  <view class="card-title">{{item.title}}</view>
                  <image 
                    wx:if="{{item.image && item.image !== ''}}" 
                    class="card-image" 
                    src="{{item.image}}" 
                    mode="aspectFill"
                    binderror="onImageError"
                    data-src="{{item.image}}"
                  ></image>
                </view>
                <view class="card-arrow">→</view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showModal}}" bindtap="onCloseModal" catchtouchmove="preventTouchMove">
    <view class="modal-container" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-year">{{currentEvent.year}}</view>
        <text class="modal-title">{{currentEvent.title}}</text>
      </view>
    
    <scroll-view class="modal-scroll-content" scroll-y enhanced show-scrollbar="{{false}}" catchtouchmove="preventTouchMove">
      <view class="modal-text-wrapper">
        <text class="modal-text">{{currentEvent.description}}</text>
      </view>
      <view wx:if="{{currentEvent.image && currentEvent.image !== ''}}" class="modal-image-wrapper">
        <image class="modal-image" src="{{currentEvent.image}}" mode="widthFix" binderror="onImageError" data-src="{{currentEvent.image}}"></image>
      </view>
    </scroll-view>
    
    <view class="modal-close" bindtap="onCloseModal">关 闭</view>
  </view>
</view>