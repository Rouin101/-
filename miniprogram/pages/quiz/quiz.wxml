<!--pages/quiz/quiz.wxml-->
<view class="container">

<!-- 开始页 -->
<view class="home-full" wx:if="{{showHome}}">
  <view class="home-title">吴健雄 · 知识问答</view>
  <view class="home-subtitle">“世界物理女王”的生平知多少？</view>
  <view class="home-btns">
    <button class="start-btn" bindtap="startQuiz">开始答题</button>
    <button class="rank-btn-text" bindtap="goToRank">查看排行榜</button>
  </view>
</view>

<!-- 答题页 -->
<view class="quiz-wrap" wx:if="{{showQuiz}}">
  <view class="progress-bar">
    <view class="progress" style="width: {{(currentIndex + 1) / questions.length * 100}}"></view>
  </view>
  <view class="quiz-card">
    <view class="question-info">
      <text class="type-tag">{{questions[currentIndex].type === 'choice' ? '单选题' : '判断题'}}</text>
      <text class="count-text">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
    </view>
    <view class="question-content">{{questions[currentIndex].question}}</view>
    <view class="options-container">
      <view 
        class="option-item {{questions[currentIndex].userAnswer === index ? 'selected' : ''}}"
        wx:for="{{questions[currentIndex].options}}" 
        wx:key="index"
        bindtap="selectOption"
        data-index="{{index}}"
      >
        {{item}}
      </view>
    </view>
  </view>
  <button class="next-btn-fixed" bindtap="nextQuestion" disabled="{{questions[currentIndex].userAnswer === undefined}}">
    {{currentIndex === questions.length - 1 ? '提交结果' : '下一题'}}
  </button>
</view>

<!-- 结果页 -->
<view class="result-full" wx:if="{{showResult}}">
  <view class="score-title">挑战完成！</view>
  <view class="score-num">{{score}} <text class="unit">分</text></view>
  <view class="score-desc">{{score === 100 ? '满分！物理学真传人' : (score >= 80 ? '卓越的物理学守望者' : '继续加油，深入了解吴教授')}}</view>
  <button class="r-btn" bindtap="uploadAndRank">上传分数并查看排行榜</button>
  <button class="r-btn retry-btn" bindtap="viewErrors">查看错题解析</button>
  <button class="r-btn retry-btn" bindtap="restart">重新挑战</button>
</view>

<!-- 排行榜页 -->
<view class="rank-page" wx:if="{{showRank}}">
  <view class="rank-title">🏆 积分排行榜</view>
  <scroll-view scroll-y class="rank-list">
    <view class="rank-item" wx:for="{{rankList}}" wx:key="index">
      <view class="rank-left">
        <text class="rank-num {{index === 0 ? 'gold' : (index === 1 ? 'silver' : (index === 2 ? 'bronze' : ''))}}">
          {{index + 1}}
        </text>
        <text class="rank-name">{{item.nickName}}</text>
      </view>
      <text class="rank-score">{{item.score}} 分</text>
    </view>
    <view wx:if="{{rankList.length === 0}}" class="empty-tip">暂无数据，快来作答吧~</view>
  </scroll-view>
  <button class="r-btn retry-btn" bindtap="restart">返回首页</button>
</view>

<!-- 错题页 -->
<view class="error-page" wx:if="{{showError}}">
  <view class="rank-title">📝 错题解析</view>
  <scroll-view scroll-y class="error-list">
    <view class="error-item" wx:for="{{wrongList}}" wx:key="index">
      <text class="eq">{{item.question}}</text>
      <text class="ek">✅ 解析：{{item.knowledge}}</text>
    </view>
  </scroll-view>
  <button class="r-btn retry-btn" bindtap="restart">重新答题</button>
</view>

</view>