/* 整体背景 */
.container {
  background: linear-gradient(165deg, #f8f2fc 0%, #eedef7 100%);
  min-height: 100vh;
  padding: 0;
}

/* ========= 开始页（全屏） ========= */
.home-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.home-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #6B35A0;
  letter-spacing: 8rpx;
  text-shadow: 2rpx 2rpx 8rpx rgba(107, 53, 160, 0.15);
  margin-bottom: 30rpx;
}

.home-subtitle {
  font-size: 30rpx;
  color: #888;
  margin-bottom: 80rpx;
  letter-spacing: 2rpx;
}

.home-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.start-btn {
  width: 80%;
  height: 100rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 8rpx 20rpx rgba(107, 53, 160, 0.4);
  color: #fff;
  border-radius: 60rpx;
  font-size: 38rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s;
}
.start-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.4);
}

.rank-btn-text {
  width: 80%;
  height: 96rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10rpx);
  color: #6B35A0;
  border: 2rpx solid #6B35A0;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.rank-btn-text:active {
  background: #f3e8f9;
  transform: scale(0.96);
}

/* ========= 答题区域 ========= */
.quiz-wrap {
  padding-top: 60rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 20rpx;
  margin: 0 0 30rpx 0;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: inset 0 1rpx 4rpx rgba(0,0,0,0.05);
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #9b65c4, #6B35A0);
  border-radius: 20rpx;
  box-shadow: 0 0 12rpx rgba(107, 53, 160, 0.6);
  transition: width 0.4s ease;
}

/* 答题卡片 */
.quiz-card {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  padding: 40rpx;
  margin: 30rpx auto;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(107, 53, 160, 0.12);
  width: 690rpx;
  max-width: calc(100vw - 60rpx);
  flex-shrink: 0;
  box-sizing: border-box;
  height: auto;
  overflow-y: auto;
  border: 1rpx solid rgba(107, 53, 160, 0.5);
}

.question-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-tag {
  font-size: 24rpx;
  background: rgba(107, 53, 160, 0.1);
  backdrop-filter: blur(8rpx);
  color: #6B35A0;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.count-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.question-content {
  font-size: 38rpx;
  font-weight: bold;
  margin: 36rpx 0 50rpx 0;
  line-height: 1.5;
  text-align: center;
  color: #2d2d3f;
  letter-spacing: 1rpx;
  word-break: break-all;
}

.options-container {
  margin-bottom: 20rpx;
}

.option-item {
  padding: 28rpx 34rpx;
  background: #fafbff;
  border: 2rpx solid #e8e6f5;
  border-radius: 20rpx;
  margin-bottom: 22rpx;
  font-size: 32rpx;
  color: #333;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}
.option-item:active {
  transform: scale(0.98);
  background: #f3e8f9;
}
.option-item.selected {
  background: linear-gradient(135deg, #f3e8f9, #eedef7);
  border-color: #6B35A0;
  color: #6B35A0;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(107, 53, 160, 0.12);
  transform: scale(1.01);
}

/* 按钮行 */
.btn-row {
  display: flex;
  width: 100%;
  gap: 20rpx;
  padding: 0 40rpx 0 30rpx;
  box-sizing: border-box;
  margin-top: 30rpx;
  justify-content: flex-start;
  align-items: center;
}

/* 上一题按钮 */
.prev-btn {
  width: 130rpx;
  height: 100rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.9);
  color: #6B35A0;
  border: 2rpx solid #6B35A0;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.1);
  transition: all 0.2s;
}
.prev-btn:active {
  background: #f3e8f9;
  transform: scale(0.96);
}
.prev-btn::after {
  display: none;
}

/* 下一题/提交按钮 */
.next-btn-fixed {
  flex: 1;
  height: 100rpx;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 8rpx 24rpx rgba(107, 53, 160, 0.35);
  color: #fff;
  border-radius: 60rpx;
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s;
}
.next-btn-fixed:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 14rpx rgba(107, 53, 160, 0.4);
}
.next-btn-fixed::after {
  display: none;
}

/* 未作答灰色禁用 */
.next-btn-fixed[disabled] {
  background: #d1d5db;
  box-shadow: none;
  color: #fff;
  opacity: 0.7;
}

/* ========= 结果页 ========= */
.result-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  text-align: center;
}

.score-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
}

.score-num {
  font-size: 160rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #9b65c4, #6B35A0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 20rpx;
  text-shadow: 0 0 40rpx rgba(107, 53, 160, 0.2);
}

.unit {
  font-size: 38rpx;
  color: #888;
  margin-left: 12rpx;
}

.score-desc {
  font-size: 32rpx;
  color: #6b7280;
  margin: 30rpx 0 60rpx 0;
  font-weight: 500;
}

.r-btn {
  width: 80%;
  margin: 20rpx 0;
  background: linear-gradient(135deg, #8a4bb3, #6B35A0);
  box-shadow: 0 8rpx 20rpx rgba(107, 53, 160, 0.35);
  color: #fff;
  border-radius: 60rpx;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s;
}
.r-btn:active {
  transform: scale(0.97);
}

.retry-btn {
  background: rgba(255,255,255,0.9);
  color: #6B35A0;
  border: 2rpx solid #6B35A0;
  border-radius: 60rpx;
  width: 80%;
  margin: 20rpx auto;
  font-size: 34rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.1);
  transition: all 0.2s;
}
.retry-btn:active {
  background: #f3e8f9;
  transform: scale(0.97);
}

/* ========= 排行榜页 ========= */
.rank-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  box-sizing: border-box;
  background: transparent;
}

.rank-title {
  font-size: 44rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 4rpx;
  flex-shrink: 0;
  margin-bottom: 30rpx;
  padding-top: 60rpx;
  color: #333;
  text-shadow: 1rpx 1rpx 4rpx rgba(107,53,160,0.1);
}

.rank-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 20rpx;
  width: 100vw;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.rank-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 24rpx 30rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8rpx);
  border-bottom: none;
  margin-bottom: 14rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(107, 53, 160, 0.06);
  transition: all 0.2s;
  border: 1rpx solid rgba(107,53,160,0.7);
}
.rank-item:active {
  transform: scale(0.98);
  background: #faf9ff;
}

.rank-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.rank-name {
  margin-left: 15rpx;
  font-size: 30rpx;
  font-weight: 500;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #222;
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 28rpx;
  line-height: 1;
  background: #eedef7;
  color: #666;
  margin-right: 15rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.rank-num.gold {
  background: linear-gradient(135deg, #fcd34d, #f59e0b);
  color: #fff;
  font-size: 36rpx;
}
.rank-num.silver {
  background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
  color: #fff;
  font-size: 34rpx;
}
.rank-num.bronze {
  background: linear-gradient(135deg, #e4a16f, #cd7f32);
  color: #fff;
  font-size: 32rpx;
}

.rank-score {
  font-size: 30rpx;
  color: #6B35A0;
  font-weight: bold;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.rank-item:first-child .rank-name,
.rank-item:nth-child(2) .rank-name,
.rank-item:nth-child(3) .rank-name {
  font-weight: bold;
  font-size: 32rpx;
  color: #111;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 40rpx;
  font-size: 30rpx;
}

.rank-page .retry-btn {
  flex-shrink: 0;
  width: 80%;
  margin: 0 auto 30rpx auto;
  background: rgba(255,255,255,0.9);
  color: #6B35A0;
  border: 2rpx solid #6B35A0;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(107, 53, 160, 0.1);
}

/* ========= 错题页 ========= */
.error-page {
  padding: 60rpx 40rpx;
  min-height: 100vh;
}

.error-list {
  max-height: 60vh;
  margin-bottom: 30rpx;
}

.error-item {
  background: #fef2f4;
  border-left: 8rpx solid #f87171;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.eq {
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
  color: #b91c1c;
  font-size: 30rpx;
}

.ek {
  color: #444;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 退出答题按钮 */
.exit-btn {
  position: fixed;
  left: 30rpx;
  top: 90rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(107,53,160,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  transition: all 0.2s;
}
.exit-btn:active {
  background: rgba(255,255,255,0.9);
  transform: scale(0.92);
}

.exit-icon {
  font-size: 36rpx;
  color: #6B35A0;
  font-weight: bold;
  line-height: 1;
}

.exit-btn-hover {
  background: rgba(255,255,255,0.95);
  box-shadow: 0 4rpx 16rpx rgba(107,53,160,0.2);
}