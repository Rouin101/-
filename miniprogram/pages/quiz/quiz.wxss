/* pages/quiz/quiz.wxss */
/* 页面滚动锁定 */
.page-container {
  min-height: 100vh;
}

.no-scroll {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}
/* 整体背景 */
.container {
  background: linear-gradient(165deg, #f0f4fa 0%, #e8edf5 100%);
  min-height: 100vh;
  padding: 0;
}

/* ========= 开始页（全屏） ========= */
.home-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}
.home-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #2d5ba1;
  margin-bottom: 20rpx;
}
.home-subtitle {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 80rpx;
}
.home-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.start-btn {
  width: 80%;
  height: 100rpx;
  background: #2d5ba1;
  color: #fff;
  border-radius: 50rpx;
  font-size: 36rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rank-btn-text {
  width: 80%;
  height: 96rpx;
  background: #fff;
  color: #2d5ba1;
  border: 2rpx solid #2d5ba1;
  border-radius: 50rpx;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========= 答题区域 - 题目框宽度保持不变 ========= */
.quiz-wrap {
  padding: 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding-top: 80rpx;
}
.progress-bar {
  height: 10rpx;
  background: #e0e0e0;
  border-radius: 5rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
}
.progress {
  height: 100%;
  background: #2d5ba1;
  transition: width 0.3s;
}

/* 题目卡片 - 固定宽度比例，不会随页面变化 */
.quiz-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  flex: 0 0 auto;
  width: 100%;
  box-sizing: border-box;
}
.question-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.type-tag {
  font-size: 24rpx;
  background: #eef2f8;
  color: #2d5ba1;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.count-text {
  font-size: 26rpx;
  color: #999;
}
.question-content {
  font-size: 36rpx;
  font-weight: bold;
  margin: 40rpx 0;
  line-height: 1.6;
}

.options-container {
  margin-bottom: 30rpx;
}
.option-item {
  padding: 30rpx;
  background: #f8f9fa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}
.option-item.selected {
  background: #eef2f8;
  border-color: #2d5ba1;
  color: #2d5ba1;
  font-weight: bold;
}

.next-btn-fixed {
  background: #2d5ba1;
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  width: 100%;
  margin-top: 20rpx;
}
.next-btn-fixed[disabled] {
  background: #ccc !important;
  color: #999 !important;
}

/* ========= 结果页（全屏） ========= */
.result-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  text-align: center;
}
.score-title {
  font-size: 40rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.score-num {
  font-size: 140rpx;
  font-weight: bold;
  color: #2d5ba1;
  line-height: 1;
}
.unit {
  font-size: 34rpx;
  color: #666;
  margin-left: 10rpx;
}
.score-desc {
  font-size: 30rpx;
  color: #666;
  margin: 40rpx 0;
}

.r-btn {
  width: 80%;
  margin: 20rpx 0;
  background: #2d5ba1;
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.retry-btn {
  background: transparent;
  color: #666;
  border: 1rpx solid #ddd;
}

/* ========= 排行榜页 - 宽度占满页面 ========= */
.rank-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 60rpx 0 40rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, #f0f4fa 0%, #e8edf5 100%);
  width: 100%;
}
.rank-title {
  font-size: 44rpx;
  font-weight: bold;
  text-align: center;
  flex-shrink: 0;
  margin-bottom: 40rpx;
  padding: 0 30rpx;
  color: #2d5ba1;
}
.rank-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 30rpx;
  padding: 0;
  width: 100%;
}

/* 列表项 - 宽度占满，不留过多空白 */
.rank-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 0;
  box-sizing: border-box;
  width: 100%;
  border-radius: 0;
}

/* 左侧区域 - 占满剩余空间 */
.rank-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  padding-left: 60rpx;
}

.rank-name {
  margin-left: 20rpx;
  font-size: 32rpx;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #333;
}

/* 分数 - 右侧留适当边距 */
.rank-score {
  font-size: 32rpx;
  color: #2d5ba1;
  font-weight: bold;
  padding-right: 60rpx;
  flex-shrink: 0;
}

/* 排名数字样式 */
.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 28rpx;
  line-height: 1;
  background: #f0f0f0;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.rank-num.gold { background: #ffd700; color: #fff; font-size: 32rpx; }
.rank-num.silver { background: #c0c0c0; color: #fff; font-size: 30rpx; }
.rank-num.bronze { background: #cd7f32; color: #fff; font-size: 28rpx; }

/* 空数据提示 */
.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

/* 返回首页按钮 */
.rank-back-btn {
  flex-shrink: 0;
  width: 80%;
  margin: 20rpx auto 0;
  background: #2d5ba1;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 34rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========= 错题页 ========= */
.error-page {
  padding: 60rpx 40rpx;
  min-height: 100vh;
}
.error-list {
  max-height: 60vh;
  margin-bottom: 30rpx;
}
.error-item {
  background: #fff4f4;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.eq {
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}
.ek {
  color: #555;
  font-size: 28rpx;
}

/* 前三名加粗 */
.rank-item:first-child .rank-name,
.rank-item:nth-child(2) .rank-name,
.rank-item:nth-child(3) .rank-name {
  font-weight: bold;
  font-size: 32rpx;
}