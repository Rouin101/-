/* miniprogram/pages/timeline/timeline.wxss */
.page-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0a0a14;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 粒子背景层 */
.particle-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  pointer-events: auto;
}

.overlay-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 2;
  pointer-events: none;
}

/* 章节指示器（右侧）- 缩小点尺寸避免与卡片重叠 */
.chapter-indicator {
  position: fixed;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: opacity 0.6s ease;
}

.chapter-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.chapter-dot.active {
  background: #FFD700;
  border-color: #FFD700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.7);
  width: 14rpx;
  height: 14rpx;
}

.chapter-line {
  width: 2rpx;
  height: 20rpx;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
}

/* 章节标签 */
.chapter-label {
  position: fixed;
  top: 160rpx;
  right: 80rpx;
  z-index: 9;
  opacity: 0;
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10rpx);
  padding: 12rpx 24rpx;
  border-radius: 60rpx;
  text-align: center;
  border: 1rpx solid rgba(255,215,0,0.3);
}

.chapter-label.visible {
  opacity: 1;
  transform: translateX(0);
}

.chapter-label-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFD700;
  letter-spacing: 4rpx;
}

.chapter-label-sub {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 时间轴滚动区域 */
.timeline-scroll {
  position: relative;
  z-index: 5;
  width: 100vw;
  height: 100vh;
  scroll-behavior: smooth;
}

/* 英雄区域 */
.hero-section {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  position: relative;
}

.hero-portrait-frame {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  position: relative;
  margin-bottom: 40rpx;
  border: 4rpx solid rgba(255, 215, 0, 0.4);
  box-shadow: 0 0 80rpx rgba(100, 140, 220, 0.4);
  overflow: hidden;
}

.hero-portrait-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.hero-glow {
  position: absolute;
  top: -30rpx;
  left: -30rpx;
  right: -30rpx;
  bottom: -30rpx;
  border-radius: 50%;
  background: transparent;
  box-shadow: 0 0 120rpx rgba(140, 180, 255, 0.35);
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 80rpx rgba(140, 180, 255, 0.25); }
  50% { box-shadow: 0 0 160rpx rgba(180, 200, 255, 0.5); }
}

.hero-title-block {
  text-align: center;
}

.hero-name {
  display: block;
  font-size: 64rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 12rpx;
  text-shadow: 0 0 60rpx rgba(200, 180, 140, 0.6);
}

.hero-name-en {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  font-style: italic;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: #FFD700;
  margin-top: 16rpx;
  letter-spacing: 6rpx;
}

.hero-years {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: hintFloat 2s ease-in-out infinite;
}

@keyframes hintFloat {
  0%, 100% { transform: translateY(0); opacity: 0.6; }
  50% { transform: translateY(-16rpx); opacity: 1; }
}

.scroll-hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
}

.scroll-hint-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 章节过渡 */
.chapter-transition {
  height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.transition-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
}

.transition-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  z-index: 1;
  text-shadow: 0 0 40rpx rgba(255, 215, 0, 0.5);
}

.transition-quote {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
  z-index: 1;
  font-style: italic;
}

/* 时间轴轨道 */
.timeline-track {
  position: relative;
  padding: 60rpx 0;
}

.timeline-central-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(140, 180, 255, 0.6) 5%,
    rgba(140, 180, 255, 0.8) 50%,
    rgba(140, 180, 255, 0.6) 95%,
    transparent 100%
  );
  transform: translateX(-50%);
}

/* 卡片容器 – 添加浮现动画 */
.timeline-card-wrapper {
  position: relative;
  margin: 40rpx 0;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  min-height: 260rpx;
  opacity: 0;
  transform: translateY(60rpx);
  transition: opacity 0.6s ease, transform 0.6s ease;
  overflow: visible;
}

.timeline-card-wrapper.visible {
  opacity: 1;
  transform: translateY(0);
}

/* 奇数项：卡片在左，右侧预留中央线空间 */
.timeline-card-wrapper:nth-child(odd) {
  flex-direction: row;
  padding-right: calc(50% + 20rpx);
}

/* 偶数项：卡片在右，左侧预留中央线空间 */
.timeline-card-wrapper:nth-child(even) {
  flex-direction: row-reverse;
  padding-left: calc(50% + 20rpx);
}

.timeline-card-3d {
  transition: transform 0.3s ease;
  cursor: pointer;
  width: 100%;
}

.card-inner {
  position: relative;
  transform-style: preserve-3d;
}

/* 玻璃态卡片 */
.glass-card {
  background: rgba(20, 24, 45, 0.85);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.glass-card:active {
  transform: scale(0.98);
}

/* 卡片主体宽度限制，防止溢出 */
.card-body {
  max-width: 330rpx;
  min-height: 240rpx;
}

.card-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.card-content {
  padding: 20rpx 24rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFD700;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.card-description {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

/* 年份标记 – 紧贴中轴线，避免重叠 */
.card-year-badge {
  position: absolute;
  top: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 2;
  white-space: nowrap;
}

/* 奇数项（卡片在左）：年份标记靠右，紧贴中轴线 */
.timeline-card-wrapper:nth-child(odd) .card-year-badge {
  left: auto;
  right: -160rpx;      /* 增大偏移量，使年份标记更靠近中轴线 */
  flex-direction: row-reverse;
}

/* 偶数项（卡片在右）：年份标记靠左，紧贴中轴线 */
.timeline-card-wrapper:nth-child(even) .card-year-badge {
  right: auto;
  left: -160rpx;       /* 增大偏移量，使年份标记更靠近中轴线 */
  flex-direction: row;
}

.year-number {
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(140, 180, 255, 0.6);
}

/* 黄点尺寸缩小 */
.year-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FFD700;
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.6);
}

/* 时间线节点 */
.timeline-node {
  position: absolute;
  left: 50%;
  top: 26rpx;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(140, 180, 255, 0.5);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  transition: all 0.5s ease;
  z-index: 3;
}

.timeline-node.node-active {
  background: #FFD700;
  border-color: #FFD700;
  box-shadow: 0 0 28rpx rgba(255, 215, 0, 0.8);
  width: 32rpx;
  height: 32rpx;
}

.node-ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 215, 0, 0.5);
  animation: rippleExpand 2s ease-out infinite;
}

@keyframes rippleExpand {
  0% { width: 24rpx; height: 24rpx; opacity: 0.8; }
  100% { width: 80rpx; height: 80rpx; opacity: 0; }
}

/* 数据可视化区域 */
.data-viz-section {
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.viz-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
  margin-bottom: 30rpx;
}

.data-viz-canvas {
  width: 600rpx;
  height: 400rpx;
  border-radius: 20rpx;
  background: rgba(20, 24, 45, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.viz-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-top: 30rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-item text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 致敬长河区域 */
.tribute-section {
  padding: 80rpx 40rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tribute-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.tribute-description {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
  text-align: center;
}

.tribute-canvas {
  width: 100%;
  height: 0rpx;
  border-radius: 20rpx;
}

/* 新增的致敬长河图片样式，缩小与上下内容的间距 */
.tribute-image {
  width: 100%;
  margin: 16rpx 0 8rpx 0; /* 原为30rpx 0 30rpx 0，缩小上下边距 */
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

/* 缩小致敬区域与语录的距离，原 margin-top:20rpx，现调小 */
.tribute-message {
  margin-top: 30rpx;
  text-align: center;
}

.tribute-quote-text {
  display: block;
  font-size: 28rpx;
  color: #FFD700;
  font-style: italic;
  letter-spacing: 3rpx;
}

.tribute-author {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
}

/* 宇称不守恒彩蛋 */
.parity-hint {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 15;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: rgba(20, 24, 45, 0.85);
  border: 1rpx solid rgba(255, 215, 0, 0.5);
  border-radius: 40rpx;
  opacity: 0;
  transition: all 0.5s ease;
  pointer-events: none;
}

.parity-hint.hint-visible {
  opacity: 1;
  pointer-events: auto;
}

.parity-hint-text {
  font-size: 24rpx;
  color: #FFD700;
}

.parity-arrow {
  font-size: 32rpx;
  color: #fff;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.parity-arrow.reversed {
  transform: rotate(180deg);
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #0a0a14;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #FFD700;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 30rpx;
  letter-spacing: 4rpx;
}

/* 底部留白 */
.bottom-spacer {
  height: 200rpx;
}

/* 详情浮层样式 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.85);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(12rpx);
}

.detail-container {
  width: 640rpx;
  max-height: 80vh;
  background: rgba(20,24,45,0.98);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,215,0,0.4);
  overflow-y: auto;
  padding-bottom: 40rpx;
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.detail-year {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFD700;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
}

.detail-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.detail-content {
  padding: 32rpx;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFD700;
  margin-bottom: 24rpx;
}

.detail-description {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(255,255,255,0.85);
}